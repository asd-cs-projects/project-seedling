{
  "name": "Lovable Self-Host (Supabase + Vite)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [5173, 54321, 54323],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" },
    "54321": { "label": "Supabase API (local)" },
    "54323": { "label": "Supabase Studio (local)" }
  },
  "remoteEnv": {
    "SUPABASE_PROJECT_REF": "bwehlqgjebghfnbrlpgd",
    "SUPABASE_URL": "https://bwehlqgjebghfnbrlpgd.supabase.co"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "denoland.vscode-deno",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "supabase.vscode-supabase-extension"
      ]
    }
  }
}
